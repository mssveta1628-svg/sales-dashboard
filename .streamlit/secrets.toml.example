# Скопируйте этот файл в .streamlit/secrets.toml и заполните данными
# (secrets.toml НЕ коммитится в GitHub — он в .gitignore)

[texmod]
host     = "your-texmod-host"
port     = 5432
dbname   = "texmod"
user     = "your_user"
password = "your_password"

[dwh]
host     = "your-dwh-host"
port     = 5432
dbname   = "dwh"
user     = "your_user"
password = "your_password"
